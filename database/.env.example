# GrayFSM Database Environment Configuration
# Copy this file to .env and customize for your environment

# ============================================================
# ENVIRONMENT
# ============================================================
ENVIRONMENT=development  # development, staging, production

# ============================================================
# POSTGRESQL CONFIGURATION
# ============================================================
POSTGRES_DB=grayfsm
POSTGRES_USER=grayfsm_user
POSTGRES_PASSWORD=grayfsm_password
POSTGRES_PORT=5432

# Database Connection String (for application)
DATABASE_URL=postgresql+asyncpg://grayfsm_user:grayfsm_password@localhost:5432/grayfsm

# ============================================================
# PGADMIN CONFIGURATION
# ============================================================
PGADMIN_EMAIL=admin@grayfsm.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# ============================================================
# REDIS CONFIGURATION
# ============================================================
REDIS_PASSWORD=redis_password
REDIS_PORT=6379
REDIS_URL=redis://:redis_password@localhost:6379/0

# ============================================================
# BACKUP CONFIGURATION
# ============================================================
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE="0 2 * * *"  # Daily at 2 AM

# ============================================================
# CONNECTION POOL SETTINGS (for application)
# ============================================================
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ============================================================
# PERFORMANCE TUNING
# ============================================================
# See config/postgresql.conf for detailed PostgreSQL settings
PG_SHARED_BUFFERS=256MB
PG_EFFECTIVE_CACHE_SIZE=1GB
PG_MAINTENANCE_WORK_MEM=128MB
PG_WORK_MEM=16MB
PG_MAX_CONNECTIONS=100

# ============================================================
# MONITORING
# ============================================================
ENABLE_PG_STAT_STATEMENTS=true
SLOW_QUERY_LOG_MIN_DURATION=1000  # milliseconds

# ============================================================
# DEVELOPMENT SETTINGS
# ============================================================
# Enable query logging in development
LOG_QUERIES=false
LOG_QUERY_PLAN=false
