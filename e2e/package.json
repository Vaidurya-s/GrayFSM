{
  "name": "grayfsm-e2e-tests",
  "version": "1.0.0",
  "description": "End-to-end tests for GrayFSM using Playwright",
  "scripts": {
    "test": "playwright test",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:mobile": "playwright test --project=mobile-chrome --project=mobile-safari",
    "test:tablet": "playwright test --project=tablet-ipad",
    "test:all-browsers": "playwright test --project=chromium --project=firefox --project=webkit",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "test:critical": "playwright test tests/critical-journeys",
    "test:visual": "playwright test tests/visual-regression",
    "test:performance": "playwright test tests/performance",
    "test:accessibility": "playwright test tests/accessibility",
    "test:update-snapshots": "playwright test --update-snapshots",
    "report": "playwright show-report test-results/html-report",
    "codegen": "playwright codegen http://localhost:5173",
    "install": "playwright install --with-deps"
  },
  "keywords": ["playwright", "e2e", "testing", "grayfsm"],
  "author": "GrayFSM Team",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.40.1",
    "@axe-core/playwright": "^4.8.2",
    "typescript": "^5.3.3",
    "@types/node": "^20.10.5",
    "dotenv": "^16.3.1",
    "playwright-lighthouse": "^3.1.0"
  },
  "dependencies": {
    "lighthouse": "^11.4.0"
  }
}
