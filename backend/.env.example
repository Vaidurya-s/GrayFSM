# Environment Configuration
ENVIRONMENT=development

# Application
APP_NAME=GrayFSM API
APP_VERSION=1.0.0
DEBUG=True
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4
RELOAD=True

# Database
DATABASE_URL=postgresql+asyncpg://grayfsm:password@localhost:5432/grayfsm
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600
REDIS_MAX_CONNECTIONS=50

# Authentication (Phase 4)
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_AUDIENCE=grayfsm-api
# Account-lockout policy: lock for ACCOUNT_LOCKOUT_MINUTES after MAX_FAILED_LOGINS bad attempts.
MAX_FAILED_LOGINS=5
ACCOUNT_LOCKOUT_MINUTES=15

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
CORS_ALLOW_CREDENTIALS=True

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_ANONYMOUS=100
RATE_LIMIT_AUTHENTICATED=1000
RATE_LIMIT_WINDOW=3600
# Per-IP brute-force mitigation on auth endpoints. Window is in seconds.
RATE_LIMIT_LOGIN=5
RATE_LIMIT_LOGIN_WINDOW=60
RATE_LIMIT_REGISTER=3
RATE_LIMIT_REGISTER_WINDOW=60

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Algorithm Defaults
DEFAULT_ALGORITHM=greedy
ALGORITHM_TIMEOUT_MS=30000
MAX_FSM_STATES=256
MAX_OPTIMIZATION_TIME_MS=300000

# Export
EXPORT_CACHE_ENABLED=True
EXPORT_CACHE_TTL_DAYS=7
EXPORT_MAX_FILE_SIZE_MB=10

# Monitoring
SENTRY_DSN=
METRICS_ENABLED=True

# File Upload
MAX_UPLOAD_SIZE_MB=5
ALLOWED_UPLOAD_FORMATS=["json","csv"]
